<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
  <!-- Base application theme. -->
  <style name="Base.AppTheme" parent="Theme.Material3.DayNight.NoActionBar">
    <!-- Customize your theme here. -->
    <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
  </style>

  <style name="AppTheme" parent="Base.AppTheme" />

  <style name="Theme.MidnightMusic" parent="Theme.Material3.DayNight.NoActionBar">
    <!-- Primary brand color -->
    <item name="colorPrimary">@color/primary</item>
    <item name="colorOnPrimary">@color/on_primary</item>
    <item name="colorPrimaryContainer">@color/primary_variant</item>
    
    <!-- Secondary brand color -->
    <item name="colorSecondary">@color/accent</item>
    <item name="colorOnSecondary">@color/on_primary</item>
    
    <!-- Background colors -->
    <item name="android:colorBackground">@color/background</item>
    <item name="colorSurface">@color/surface</item>
    <item name="colorSurfaceVariant">@color/surface_variant</item>
    <item name="colorOnSurface">@color/text_primary</item>
    <item name="colorOnSurfaceVariant">@color/text_secondary</item>
    
    <!-- Status bar color -->
    <item name="android:statusBarColor">@android:color/transparent</item>
    <item name="android:navigationBarColor">@android:color/transparent</item>
    <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
    
    <!-- Typography -->
    <item name="fontFamily">@font/poppins</item>

    <!-- Component Styles -->
    <item name="materialCardViewStyle">@style/Widget.MidnightMusic.CardView</item>
    <item name="bottomNavigationStyle">@style/Widget.MidnightMusic.BottomNavigationView</item>
  </style>

  <!-- Component Styles Refinement -->
  <style name="Widget.MidnightMusic.CardView" parent="Widget.Material3.CardView.Elevated">
    <item name="cardBackgroundColor">@color/card_background</item>
    <item name="cardCornerRadius">24dp</item>
    <item name="cardElevation">2dp</item>
    <item name="shapeAppearanceOverlay">@style/ShapeAppearance.MidnightMusic.Medium</item>
  </style>

  <style name="Widget.MidnightMusic.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
    <item name="backgroundTint">@color/surface</item>
    <item name="itemIconTint">@color/primary</item>
    <item name="itemTextColor">@color/text_primary</item>
    <item name="itemRippleColor">@color/ripple_accent</item>
    <item name="elevation">0dp</item>
    <item name="labelVisibilityMode">labeled</item>
  </style>

  <style name="ShapeAppearance.MidnightMusic.Medium" parent="ShapeAppearance.Material3.Corner.Medium">
    <item name="cornerSize">24dp</item>
  </style>

  <style name="TextAppearance.MidnightMusic.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
    <item name="android:textColor">?attr/colorOnSurface</item>
    <item name="android:textSize">16sp</item>
    <item name="fontFamily">@font/poppins</item>
  </style>

  <style name="TextAppearance.MidnightMusic.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
    <item name="android:textColor">?attr/colorOnSurface</item>
    <item name="android:textSize">14sp</item>
    <item name="fontFamily">@font/poppins</item>
  </style>

  <style name="TextAppearance.MidnightMusic.BodySmall" parent="TextAppearance.Material3.BodySmall">
    <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    <item name="android:textSize">12sp</item>
    <item name="fontFamily">@font/poppins</item>
  </style>

  <!-- Dialog theme for nickname prompt -->
  <style name="Theme.MidnightMusic.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
    <item name="colorPrimary">@color/primary</item>
    <item name="colorSurface">@color/surface</item>
    <item name="materialAlertDialogTitleTextStyle">@style/TextAppearance.MidnightMusic.BodyLarge</item>
  </style>

</resources>