<?xml version="1.0" encoding="utf-8"?>
<paths>
    <!-- Expose the Downloads directory where DownloadManager saves the APK -->
    <external-path name="external_downloads" path="Download/" />
    
    <!-- Fallback/Legacy external storage root just to be safe -->
    <external-path name="external_files" path="." />
    
    <!-- Expose app-specific external files directory for reliable APK updates -->
    <external-files-path name="app_external_files" path="." />
</paths>
