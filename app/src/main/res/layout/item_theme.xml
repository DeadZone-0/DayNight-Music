<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/theme_item_container"
    android:layout_width="80dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:clickable="true"
    android:focusable="true"
    android:padding="4dp"
    android:foreground="?attr/selectableItemBackground"
    android:contentDescription="@string/theme_item_description">

    <FrameLayout
        android:layout_width="56dp"
        android:layout_height="56dp">

        <View
            android:id="@+id/theme_circle"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_theme_circle" />

        <ImageView
            android:id="@+id/check_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_check"
            android:visibility="gone"
            android:contentDescription="@string/theme_selected"
            app:tint="@android:color/white" />
    </FrameLayout>

    <TextView
        android:id="@+id/theme_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        tools:text="Midnight"
        android:textSize="11sp"
        android:textColor="@color/text_secondary"
        android:fontFamily="@font/poppins"
        android:maxLines="1"
        android:ellipsize="end" />

</LinearLayout>
