<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/miniPlayerContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginBottom="6dp"
    android:background="@drawable/bg_mini_player"
    android:clickable="true"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:elevation="12dp"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:paddingVertical="10dp"
    android:paddingStart="10dp"
    android:paddingEnd="6dp">

    <!-- Album art — rounded square -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imgMiniArt"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.MiniPlayer.Art" />

    <!-- Song title -->
    <TextView
        android:id="@+id/txtMiniTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="4dp"
        android:ellipsize="marquee"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:fontFamily="@font/poppins_semibold"
        android:marqueeRepeatLimit="marquee_forever"
        android:maxLines="1"
        android:singleLine="true"
        android:textColor="@color/white"
        android:textSize="14sp"
        app:layout_constraintBottom_toTopOf="@id/txtMiniArtist"
        app:layout_constraintEnd_toStartOf="@id/btnMiniHeart"
        app:layout_constraintStart_toEndOf="@id/imgMiniArt"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        tools:text="Blinding Lights" />

    <!-- Artist name -->
    <TextView
        android:id="@+id/txtMiniArtist"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="1dp"
        android:layout_marginEnd="4dp"
        android:ellipsize="end"
        android:fontFamily="@font/poppins"
        android:maxLines="1"
        android:textColor="#88FFFFFF"
        android:textSize="11sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnMiniHeart"
        app:layout_constraintStart_toEndOf="@id/imgMiniArt"
        app:layout_constraintTop_toBottomOf="@id/txtMiniTitle"
        tools:text="The Weeknd" />

    <!-- Favorite / Heart button -->
    <ImageButton
        android:id="@+id/btnMiniHeart"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Favorite"
        android:padding="5dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_favorite_border"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnMiniPlayPause"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#88FFFFFF" />

    <!-- Play/Pause button — the primary action -->
    <ImageButton
        android:id="@+id/btnMiniPlayPause"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/play_pause"
        android:padding="6dp"
        android:scaleType="centerInside"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnMiniNext"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white"
        tools:src="@drawable/ic_play_rounded" />

    <!-- Next button -->
    <ImageButton
        android:id="@+id/btnMiniNext"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/next"
        android:padding="5dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_skip_next_rounded"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#88FFFFFF" />

    <!-- Progress bar — ultra-thin accent line pinned to the absolute bottom -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progressMini"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="0dp"
        app:indicatorColor="@color/primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:trackColor="@android:color/transparent"
        app:trackCornerRadius="2dp"
        app:trackThickness="2dp" />

</androidx.constraintlayout.widget.ConstraintLayout>