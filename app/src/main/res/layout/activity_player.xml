<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
     xmlns:android="http://schemas.android.com/apk/res/android"
     xmlns:app="http://schemas.android.com/apk/res-auto"
     xmlns:tools="http://schemas.android.com/tools"
     android:layout_height="match_parent"
     android:layout_width="match_parent"
     android:background="#121212"
     android:transitionGroup="true">

    <!-- Blurred background image overlay -->
    <ImageView
         android:layout_height="match_parent"
         android:layout_width="match_parent"
         android:scaleType="centerCrop"
         android:alpha="0.15"
         app:layout_constraintTop_toTopOf="parent"
         android:id="@+id/backgroundImage" />

    <!-- Gradient overlay for depth -->
    <View
         android:layout_width="match_parent"
         android:layout_height="match_parent"
         android:background="@drawable/gradient_fade_bottom"
         app:layout_constraintTop_toTopOf="parent" />

    <!-- ═══════════════════════════════════════════ -->
    <!-- TOP BAR: Chevron + "NOW PLAYING" + Options  -->
    <!-- ═══════════════════════════════════════════ -->

    <ImageButton
         android:layout_height="44dp"
         android:layout_width="44dp"
         android:contentDescription="@string/close"
         android:src="@drawable/ic_chevron_down_rounded"
         android:background="?attr/selectableItemBackgroundBorderless"
         app:layout_constraintTop_toTopOf="parent"
         android:layout_marginTop="48dp"
         android:layout_marginStart="16dp"
         app:layout_constraintStart_toStartOf="parent"
         app:tint="@color/white"
         android:id="@+id/btnClose" />

    <TextView
         android:layout_width="wrap_content"
         android:layout_height="wrap_content"
         android:text="@string/now_playing"
         android:textColor="#B3FFFFFF"
         android:textSize="12sp"
         android:letterSpacing="0.15"
         android:textAllCaps="true"
         android:fontFamily="@font/poppins_semibold"
         app:layout_constraintTop_toTopOf="@id/btnClose"
         app:layout_constraintBottom_toBottomOf="@id/btnClose"
         app:layout_constraintStart_toStartOf="parent"
         app:layout_constraintEnd_toEndOf="parent"
         android:id="@+id/txtNowPlayingLabel" />

    <ImageButton
         android:layout_height="44dp"
         android:layout_width="44dp"
         android:contentDescription="@string/options"
         android:src="@drawable/ic_more_vert"
         android:background="?attr/selectableItemBackgroundBorderless"
         app:layout_constraintTop_toTopOf="@id/btnClose"
         app:layout_constraintBottom_toBottomOf="@id/btnClose"
         android:layout_marginEnd="16dp"
         app:tint="@color/white"
         app:layout_constraintEnd_toEndOf="parent"
         android:id="@+id/btnOptions" />

    <!-- ══════════════════════════════════ -->
    <!-- ALBUM ART WITH VINYL DISC BEHIND  -->
    <!-- ══════════════════════════════════ -->

    <!-- Vinyl disc behind the album art, peeking from the right -->
    <ImageView
         android:id="@+id/imgVinylDisc"
         android:layout_width="0dp"
         android:layout_height="0dp"
         android:src="@drawable/bg_vinyl_disc"
         android:alpha="0.85"
         app:layout_constraintDimensionRatio="1:1"
         app:layout_constraintWidth_percent="0.72"
         app:layout_constraintStart_toStartOf="parent"
         app:layout_constraintEnd_toEndOf="parent"
         android:layout_marginStart="48dp"
         android:layout_marginTop="24dp"
         app:layout_constraintTop_toBottomOf="@id/btnClose"
         app:layout_constraintHorizontal_bias="0.65" />

    <!-- Main Album Art - centered -->
    <com.google.android.material.imageview.ShapeableImageView
         android:layout_height="0dp"
         android:layout_width="0dp"
         android:scaleType="centerCrop"
         app:layout_constraintDimensionRatio="1:1"
         app:layout_constraintStart_toStartOf="parent"
         app:layout_constraintEnd_toEndOf="parent"
         app:layout_constraintWidth_percent="0.75"
         android:layout_marginTop="24dp"
         app:shapeAppearanceOverlay="@style/ShapeAppearance.Album.Player"
         android:transitionName="transition_album_art"
         android:elevation="8dp"
         app:layout_constraintTop_toBottomOf="@id/btnClose"
         app:layout_constraintHorizontal_bias="0.45"
         android:id="@+id/imgAlbumArt" />

    <!-- ══════════════════════════════════════ -->
    <!-- SONG INFO: Title + Artist + Like      -->
    <!-- ══════════════════════════════════════ -->

    <TextView
         android:layout_height="wrap_content"
         android:layout_width="0dp"
         android:ellipsize="marquee"
         android:marqueeRepeatLimit="marquee_forever"
         android:singleLine="true"
         android:focusable="true"
         android:focusableInTouchMode="true"
         android:textSize="24sp"
         android:textColor="@color/white"
         android:fontFamily="@font/poppins_semibold"
         android:layout_marginTop="32dp"
         android:transitionName="transition_song_title"
         app:layout_constraintTop_toBottomOf="@id/imgAlbumArt"
         android:layout_marginStart="32dp"
         android:layout_marginEnd="8dp"
         app:layout_constraintStart_toStartOf="parent"
         app:layout_constraintEnd_toStartOf="@id/btnLike"
         android:maxLines="1"
         android:id="@+id/txtSongName" />

    <!-- Heart / Like button inline with song title -->
    <ImageButton
         android:id="@+id/btnLike"
         android:layout_width="44dp"
         android:layout_height="44dp"
         android:layout_marginEnd="32dp"
         android:background="?attr/selectableItemBackgroundBorderless"
         android:contentDescription="@string/like"
         android:src="@drawable/ic_favorite_border"
         app:tint="@color/white"
         app:layout_constraintEnd_toEndOf="parent"
         app:layout_constraintTop_toTopOf="@id/txtSongName"
         app:layout_constraintBottom_toBottomOf="@id/txtSongName" />

    <TextView
         android:layout_height="wrap_content"
         android:layout_width="0dp"
         android:ellipsize="end"
         android:textSize="15sp"
         android:textColor="#80FFFFFF"
         android:fontFamily="@font/poppins_medium"
         android:layout_marginTop="2dp"
         android:transitionName="transition_artist_name"
         app:layout_constraintTop_toBottomOf="@id/txtSongName"
         android:layout_marginStart="32dp"
         android:layout_marginEnd="32dp"
         app:layout_constraintStart_toStartOf="parent"
         app:layout_constraintEnd_toEndOf="parent"
         android:maxLines="1"
         android:id="@+id/txtArtistName" />

    <!-- ═══════════════════════════════ -->
    <!-- CONTROLS CONTAINER              -->
    <!-- ═══════════════════════════════ -->

    <androidx.constraintlayout.widget.ConstraintLayout
         android:layout_height="wrap_content"
         android:layout_width="match_parent"
         android:layout_marginHorizontal="32dp"
         app:layout_constraintTop_toBottomOf="@id/txtArtistName"
         android:layout_marginTop="24dp"
         android:paddingBottom="16dp"
         android:id="@+id/controlsContainer">

        <!-- Slim SeekBar -->
        <SeekBar
             android:layout_height="wrap_content"
             android:layout_width="0dp"
             app:layout_constraintStart_toStartOf="parent"
             app:layout_constraintEnd_toEndOf="parent"
             app:layout_constraintTop_toTopOf="parent"
             android:progressDrawable="@drawable/bg_seekbar_track"
             android:thumb="@drawable/bg_seekbar_thumb"
             android:thumbTint="@color/white"
             android:maxHeight="4dp"
             android:minHeight="4dp"
             android:paddingTop="16dp"
             android:paddingBottom="16dp"
             android:id="@+id/seekBar" />

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="wrap_content"
             app:layout_constraintStart_toStartOf="@id/seekBar"
             android:textSize="12sp"
             android:textColor="#80FFFFFF"
             android:fontFamily="@font/poppins_medium"
             android:layout_marginTop="0dp"
             tools:text="1:24"
             app:layout_constraintTop_toBottomOf="@id/seekBar"
             android:id="@+id/txtCurrentTime" />

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="wrap_content"
             android:textSize="12sp"
             android:textColor="#80FFFFFF"
             android:fontFamily="@font/poppins_medium"
             app:layout_constraintEnd_toEndOf="@id/seekBar"
             android:layout_marginTop="0dp"
             tools:text="3:42"
             app:layout_constraintTop_toBottomOf="@id/seekBar"
             android:id="@+id/txtTotalTime" />

        <!-- ════════════════════════════════════ -->
        <!-- MAIN TRANSPORT: shuffle prev play next repeat -->
        <!-- ════════════════════════════════════ -->

        <LinearLayout
            android:id="@+id/additionalControlsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/txtCurrentTime"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnShuffle"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/shuffle"
                android:src="@drawable/ic_shuffle_rounded"
                android:scaleType="centerInside"
                android:padding="10dp"
                app:tint="@color/gray_light" />

            <ImageButton
                android:id="@+id/btnPrevious"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="20dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/previous"
                android:src="@drawable/ic_skip_prev_rounded"
                android:scaleType="centerInside"
                android:padding="8dp"
                app:tint="@color/white" />

            <!-- Big circular Play/Pause button -->
            <FrameLayout
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:layout_marginHorizontal="20dp">

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnPlayPause"
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    android:contentDescription="@string/play_pause"
                    android:scaleType="center"
                    android:transitionName="transition_play_button"
                    app:fabCustomSize="68dp"
                    app:backgroundTint="@color/white"
                    app:maxImageSize="32dp"
                    app:tint="#121212"
                    app:elevation="4dp"
                    app:borderWidth="0dp" />
            </FrameLayout>

            <ImageButton
                android:id="@+id/btnNext"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginEnd="20dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/next"
                android:src="@drawable/ic_skip_next_rounded"
                android:scaleType="centerInside"
                android:padding="8dp"
                app:tint="@color/white" />

            <ImageButton
                android:id="@+id/btnRepeat"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/repeat"
                android:src="@drawable/ic_repeat_rounded"
                android:scaleType="centerInside"
                android:padding="10dp"
                app:tint="@color/gray_light" />

        </LinearLayout>

        <!-- ════════════════════════════════════ -->
        <!-- EXTRA ROW: Download, Playlist, Mix  -->
        <!-- ════════════════════════════════════ -->

        <LinearLayout
            android:id="@+id/extraControlsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/additionalControlsContainer">

            <ImageButton
                android:id="@+id/btnDownload"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginHorizontal="20dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Download"
                android:src="@drawable/ic_download_arrow"
                android:scaleType="centerInside"
                android:padding="10dp"
                app:tint="#B3FFFFFF" />

            <ImageButton
                android:id="@+id/btnAddToPlaylist"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginHorizontal="20dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/add_to_playlist"
                android:src="@drawable/ic_playlist_add"
                android:scaleType="centerInside"
                android:padding="10dp"
                app:tint="#B3FFFFFF" />

            <ImageButton
                android:id="@+id/btnSimilarSongs"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginHorizontal="20dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Add similar songs"
                android:src="@drawable/ic_magic_mix"
                android:scaleType="centerInside"
                android:padding="10dp"
                app:tint="#B3FFFFFF" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ══════════════════════════════ -->
    <!-- QUEUE FAB                      -->
    <!-- ══════════════════════════════ -->

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/btnShowQueue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/queue"
        android:textColor="@color/white"
        android:textSize="13sp"
        android:layout_margin="24dp"
        app:icon="@drawable/ic_queue_music"
        app:iconTint="@color/white"
        app:iconGravity="textStart"
        app:iconSize="20dp"
        android:backgroundTint="#2A2A2A"
        android:elevation="4dp"
        app:cornerRadius="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- ══════════════════════════════ -->
    <!-- QUEUE PANEL (hidden default)   -->
    <!-- ══════════════════════════════ -->

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/queueContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_rounded_top_corners"
        android:elevation="16dp"
        android:visibility="gone"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Drag handle -->
        <View
            android:id="@+id/dragHandle"
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_drag_handle"
            android:alpha="0.5"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/queueTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="20dp"
            android:text="@string/now_playing"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:fontFamily="@font/poppins_bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dragHandle" />

        <ImageButton
            android:id="@+id/btnCloseQueue"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/close_queue"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/queueTitle"
            app:layout_constraintBottom_toBottomOf="@id/queueTitle"
            app:tint="@color/white" />

        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:background="#1AFFFFFF"
            app:layout_constraintTop_toBottomOf="@id/queueTitle" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/queueRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="350dp"
            android:layout_marginTop="16dp"
            android:clipToPadding="false"
            android:paddingBottom="16dp"
            android:paddingHorizontal="12dp"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:listitem="@layout/item_queue_song" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>