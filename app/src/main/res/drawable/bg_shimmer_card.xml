<?xml version="1.0" encoding="utf-8"?>
<animation-list xmlns:android="http://schemas.android.com/apk/res/android"
    android:oneshot="false">
    <item android:duration="400">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <gradient
                android:angle="0"
                android:centerColor="@color/surface_container"
                android:endColor="@color/surface_container_high"
                android:startColor="@color/surface_container_low" />
        </shape>
    </item>
    <item android:duration="400">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <gradient
                android:angle="0"
                android:centerColor="@color/surface_container_high"
                android:endColor="@color/surface_container_highest"
                android:startColor="@color/surface_container" />
        </shape>
    </item>
    <item android:duration="400">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <gradient
                android:angle="0"
                android:centerColor="@color/surface_container_low"
                android:endColor="@color/surface_container"
                android:startColor="@color/surface_container_high" />
        </shape>
    </item>
</animation-list>
